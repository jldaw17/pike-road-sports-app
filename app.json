{
  "expo": {
    "name": "Pike Road Athletics",
    "slug": "pike-road-athletics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pikeroadathletics",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.athleticos.pikeroad",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.radioalabama.pikeroad",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#1F3B7A"
        }
      ],
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      "expo-notifications",
      "expo-video"
    ],
    "extra": {
      "schoolSlug": "pike-road",
      "youtubeApiKey": "AIzaSyAbZ_d503d_Lu4RCUqaBHxk-Qq30uOyJZY",
      "router": {},
      "eas": {
        "projectId": "70b794e3-e8d7-4919-ac83-0b034b118ea2"
      }
    },
    "owner": "jlaw171"
  }
}
